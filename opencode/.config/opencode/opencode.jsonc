{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "skill": {
      "*": "allow",
    },
  },
  "mcp": {
    "mint": {
      "type": "remote",
      "url": "https://mintlify.com/docs/mcp",
      "enabled": true,
    },
    "square": {
      "type": "remote",
      "url": "https://mcp.squareup.com/sse",
      "enabled": true,
    },
    "papermap": {
      "type": "local",
      "command": ["papermap-mcp"],
      "enabled": false,
    },
  },
}
